# Zkopírujte tento soubor jako .env.local a doplňte skutečné hodnoty.
# NIKDY nenahrávejte .env.local do GitHubu (je v .gitignore).
# Toto jsou pouze NÁZVY proměnných – žádné skutečné klíče ani hesla zde nejsou.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Produkční adresa aplikace na Vercelu – používá se pro přesměrování
# po Google přihlášení a po obnovení hesla.
NEXT_PUBLIC_SITE_URL=https://VASE-PRODUKCNI-ADRESA.vercel.app

# --- DOČASNÝ testovací bypass přihlášení (vypnout nastavením DEV_AUTO_LOGIN=false) ---
# V development módu je auto-login zapnutý automaticky.
DEV_AUTO_LOGIN=true
NEXT_PUBLIC_DEV_AUTO_LOGIN=true
# Přihlašovací údaje administrátora ze Supabase Authentication
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=
